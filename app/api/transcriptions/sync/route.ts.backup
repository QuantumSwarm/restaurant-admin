// app/api/transcriptions/sync/route.ts
// Fetch transcriptions from ElevenLabs API and sync to database

import { NextRequest, NextResponse } from 'next/server';
import { prisma } from '@/lib/db/prisma';
import { verifyToken } from '@/lib/auth/jwt';

// TODO: Move these to environment variables
const ELEVENLABS_API_URL = process.env.ELEVENLABS_API_URL || 'https://api.elevenlabs.io/v1';
const ELEVENLABS_API_KEY = process.env.ELEVENLABS_API_KEY;

interface ElevenLabsTranscription {
  conversation_id: string;
  session_id?: string;
  transcript: string;
  duration_seconds?: number;
  created_at: string;
  // Add other fields from ElevenLabs API response
  [key: string]: any;
}

export async function POST(request: NextRequest) {
  try {
    // Get token from cookie
    const token = request.cookies.get('token')?.value;

    if (!token) {
      return NextResponse.json(
        { error: 'Authentication required' },
        { status: 401 }
      );
    }

    // Verify token
    const decoded = verifyToken(token);
    if (!decoded) {
      return NextResponse.json(
        { error: 'Invalid or expired token' },
        { status: 401 }
      );
    }

    // Get request parameters
    const body = await request.json();
    const { storeId, startDate, endDate } = body;

    // Verify user has access to this store
    if (decoded.role !== 'super_admin') {
      // Admin must own the store
      const store = await prisma.$queryRawUnsafe<any[]>(`
        SELECT s.store_id 
        FROM store s
        JOIN restaurant r ON s.restaurant_id = r.restaurant_id
        WHERE s.store_id = $1 AND r.admin_id = $2
      `, storeId, decoded.adminId);

      if (store.length === 0) {
        return NextResponse.json(
          { error: 'Permission denied' },
          { status: 403 }
        );
      }
    }

    // Check if API key is configured
    if (!ELEVENLABS_API_KEY) {
      return NextResponse.json(
        { error: 'ElevenLabs API key not configured' },
        { status: 500 }
      );
    }

    // TODO: Replace with actual ElevenLabs API endpoint
    // This is a placeholder - update based on ElevenLabs documentation
    const apiUrl = `${ELEVENLABS_API_URL}/conversations/transcriptions`;
    
    const params = new URLSearchParams({
      store_id: storeId.toString(),
      start_date: startDate,
      end_date: endDate,
      // Add other required parameters
    });

    // Fetch transcriptions from ElevenLabs
    const response = await fetch(`${apiUrl}?${params}`, {
      method: 'GET',
      headers: {
        'Authorization': `Bearer ${ELEVENLABS_API_KEY}`,
        'Content-Type': 'application/json',
      },
    });

    if (!response.ok) {
      const errorText = await response.text();
      console.error('ElevenLabs API error:', errorText);
      return NextResponse.json(
        { error: 'Failed to fetch transcriptions from ElevenLabs' },
        { status: response.status }
      );
    }

    const data = await response.json();
    
    // TODO: Adjust based on actual ElevenLabs API response structure
    const transcriptions: ElevenLabsTranscription[] = data.transcriptions || [];

    // Sync transcriptions to database
    let syncedCount = 0;
    let errorCount = 0;

    for (const trans of transcriptions) {
      try {
        // Calculate word count
        const wordCount = trans.transcript.trim().split(/\s+/).length;

        // Upsert transcription (insert or update if exists)
        await prisma.$executeRawUnsafe(`
          INSERT INTO transcriptions (
            store_id,
            conversation_id,
            session_id,
            transcript_text,
            duration_seconds,
            word_count,
            created_at,
            metadata
          ) VALUES (
            $1, $2, $3, $4, $5, $6, $7::timestamp, $8::jsonb
          )
          ON CONFLICT (store_id, conversation_id)
          DO UPDATE SET
            transcript_text = EXCLUDED.transcript_text,
            duration_seconds = EXCLUDED.duration_seconds,
            word_count = EXCLUDED.word_count,
            metadata = EXCLUDED.metadata,
            updated_at = NOW()
        `,
          storeId,
          trans.conversation_id,
          trans.session_id || null,
          trans.transcript,
          trans.duration_seconds || null,
          wordCount,
          trans.created_at,
          JSON.stringify(trans)
        );

        syncedCount++;
      } catch (error) {
        console.error('Error syncing transcription:', error);
        errorCount++;
      }
    }

    return NextResponse.json({
      success: true,
      synced: syncedCount,
      errors: errorCount,
      total: transcriptions.length,
    });

  } catch (error) {
    console.error('Sync transcriptions error:', error);
    return NextResponse.json(
      { error: 'Failed to sync transcriptions' },
      { status: 500 }
    );
  }
}
