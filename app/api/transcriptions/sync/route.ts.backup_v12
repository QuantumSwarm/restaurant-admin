// app/api/transcriptions/sync/route.ts
import { NextRequest, NextResponse } from 'next/server';
import { prisma } from '@/lib/db/prisma';
import { verifyToken } from '@/lib/auth/jwt';

const ELEVENLABS_API_URL = process.env.ELEVENLABS_API_URL || 'https://api.elevenlabs.io/v1';
const ELEVENLABS_API_KEY = process.env.ELEVENLABS_API_KEY;
const MAX_DATE_RANGE_DAYS = 90;
const PAGE_SIZE = 50;

interface ConversationListItem {
  conversation_id: string;
  agent_id: string;
  agent_name?: string;
  start_time_unix_secs?: number;
  call_duration_secs?: number;
  status?: string;
  call_summary_title?: string;
}

interface TranscriptTurn {
  role: 'agent' | 'user';
  message: string | null;
  time_in_call_secs?: number;
}

interface ConversationDetail {
  conversation_id: string;
  agent_id: string;
  status?: string;
  transcript?: TranscriptTurn[];
  metadata?: {
    start_time_unix_secs?: number;
    call_duration_secs?: number;
  };
  analysis?: {
    transcript_summary?: string;
    call_summary_title?: string;
  };
}

interface ConversationListResponse {
  conversations: ConversationListItem[];
  next_cursor?: string | null;
  has_more?: boolean;
}

function dateToUnix(dateStr: string): number {
  return Math.floor(new Date(dateStr).getTime() / 1000);
}

export async function POST(request: NextRequest) {
  try {
    const token = request.cookies.get('token')?.value;
    if (!token) {
      return NextResponse.json({ error: 'Authentication required' }, { status: 401 });
    }

    const decoded = verifyToken(token);
    if (!decoded) {
      return NextResponse.json({ error: 'Invalid or expired token' }, { status: 401 });
    }

    const body = await request.json();
    const { storeId, startDate, endDate } = body;

    if (!storeId || !startDate || !endDate) {
      return NextResponse.json(
        { error: 'Missing required parameters: storeId, startDate, endDate' },
        { status: 400 }
      );
    }

    // Validate 90-day limit
    const daysDiff = Math.ceil(
      (new Date(endDate).getTime() - new Date(startDate).getTime()) / (1000 * 60 * 60 * 24)
    );
    if (daysDiff > MAX_DATE_RANGE_DAYS) {
      return NextResponse.json(
        { error: `Date range cannot exceed ${MAX_DATE_RANGE_DAYS} days` },
        { status: 400 }
      );
    }

    // Verify store access
    const storeQuery = await prisma.$queryRawUnsafe<any[]>(`
      SELECT s.store_id, s.ai_agent_id, r.admin_id
      FROM store s
      JOIN restaurant r ON s.restaurant_id = r.restaurant_id
      WHERE s.store_id = $1
    `, storeId);

    if (storeQuery.length === 0) {
      return NextResponse.json({ error: 'Store not found' }, { status: 404 });
    }

    const store = storeQuery[0];

    if (decoded.role !== 'super_admin' && store.admin_id !== decoded.adminId) {
      return NextResponse.json({ error: 'Permission denied' }, { status: 403 });
    }

    if (!store.ai_agent_id) {
      return NextResponse.json({ error: 'AI agent ID not configured for this store' }, { status: 400 });
    }

    if (!ELEVENLABS_API_KEY) {
      return NextResponse.json({ error: 'ElevenLabs API key not configured' }, { status: 500 });
    }

    const startUnix = dateToUnix(startDate);
    const endUnix = dateToUnix(endDate);

    console.log(`[ElevenLabs] Step 1: Listing conversations for agent ${store.ai_agent_id}`);
    console.log(`[ElevenLabs] Date range: ${startDate} to ${endDate} (Unix: ${startUnix} - ${endUnix})`);

    // ─── STEP 1: Get all conversation IDs ───────────────────────────────────
    const allConversationIds: string[] = [];
    let cursor: string | null = null;
    let pageCount = 0;

    do {
      const params = new URLSearchParams({
        agent_id: store.ai_agent_id,
        call_start_after_unix: startUnix.toString(),
        call_start_before_unix: endUnix.toString(),
        page_size: PAGE_SIZE.toString(),
      });

      if (cursor) params.append('cursor', cursor);

      const listUrl = `${ELEVENLABS_API_URL}/convai/conversations?${params}`;
      console.log(`[ElevenLabs] Fetching page ${pageCount + 1}...`);

      const listResponse = await fetch(listUrl, {
        headers: { 'xi-api-key': ELEVENLABS_API_KEY, 'Content-Type': 'application/json' },
      });

      if (!listResponse.ok) {
        const errorText = await listResponse.text();
        console.error('[ElevenLabs] List API error:', errorText);
        return NextResponse.json(
          { error: `ElevenLabs API error: ${listResponse.status} ${listResponse.statusText}` },
          { status: listResponse.status }
        );
      }

      const listData: ConversationListResponse = await listResponse.json();

      if (listData.conversations?.length > 0) {
        const ids = listData.conversations.map(c => c.conversation_id);
        allConversationIds.push(...ids);
        console.log(`[ElevenLabs] Page ${pageCount + 1}: ${ids.length} conversations found`);
      }

      cursor = listData.next_cursor || null;
      pageCount++;

      if (pageCount > 100) {
        console.warn('[ElevenLabs] Safety limit: 100 pages reached');
        break;
      }
    } while (cursor);

    console.log(`[ElevenLabs] Step 1 Complete: ${allConversationIds.length} conversations found`);

    // ─── STEP 2: Fetch transcript for each conversation ──────────────────────
    console.log(`[ElevenLabs] Step 2: Fetching transcripts...`);

    let syncedCount = 0;
    let errorCount = 0;
    let skippedCount = 0;

    for (let i = 0; i < allConversationIds.length; i++) {
      const conversationId = allConversationIds[i];

      try {
        const detailUrl = `${ELEVENLABS_API_URL}/convai/conversations/${conversationId}`;

        const detailResponse = await fetch(detailUrl, {
          headers: { 'xi-api-key': ELEVENLABS_API_KEY, 'Content-Type': 'application/json' },
        });

        if (!detailResponse.ok) {
          console.error(`[ElevenLabs] Failed to fetch ${conversationId}: ${detailResponse.status}`);
          errorCount++;
          continue;
        }

        const conversation: ConversationDetail = await detailResponse.json();

        // Build readable transcript from array of turns
        const transcriptText = (conversation.transcript || [])
          .filter((turn) => turn.message && turn.message.trim() !== '')
          .map((turn) => `${turn.role === 'agent' ? 'Agent' : 'Customer'}: ${turn.message}`)
          .join('\n');

        if (!transcriptText.trim()) {
          skippedCount++;
          if (skippedCount <= 3) {
            console.log(`[DEBUG] Skipped ${conversationId} - no transcript messages`);
          }
          continue;
        }

        const wordCount = transcriptText.trim().split(/\s+/).length;
        const startTimeSecs = conversation.metadata?.start_time_unix_secs;
        const createdAt = startTimeSecs
          ? new Date(startTimeSecs * 1000).toISOString()
          : new Date().toISOString();
        const durationSeconds = conversation.metadata?.call_duration_secs || null;

        await prisma.$executeRawUnsafe(`
          INSERT INTO transcriptions (
            store_id, conversation_id, session_id, transcript_text,
            duration_seconds, word_count, created_at, metadata
          ) VALUES ($1, $2, $3, $4, $5, $6, $7::timestamp, $8::jsonb)
          ON CONFLICT (store_id, conversation_id)
          DO UPDATE SET
            transcript_text = EXCLUDED.transcript_text,
            duration_seconds = EXCLUDED.duration_seconds,
            word_count = EXCLUDED.word_count,
            metadata = EXCLUDED.metadata,
            updated_at = NOW()
        `,
          storeId,
          conversationId,
          conversation.agent_id || null,
          transcriptText,
          durationSeconds,
          wordCount,
          createdAt,
          JSON.stringify({
            call_summary_title: conversation.analysis?.call_summary_title || null,
            transcript_summary: conversation.analysis?.transcript_summary || null,
            status: conversation.status,
          })
        );

        syncedCount++;

        if ((i + 1) % 10 === 0) {
          console.log(`[ElevenLabs] Progress: ${i + 1}/${allConversationIds.length}`);
        }

      } catch (error) {
        console.error(`[ElevenLabs] Error on ${conversationId}:`, error);
        errorCount++;
      }
    }

    console.log(`[Sync] Complete: ${syncedCount} synced, ${errorCount} errors, ${skippedCount} skipped`);

    return NextResponse.json({
      success: true,
      synced: syncedCount,
      errors: errorCount,
      skipped: skippedCount,
      total: allConversationIds.length,
    });

  } catch (error) {
    console.error('[Sync] Error:', error);
    return NextResponse.json({ error: 'Failed to sync transcriptions' }, { status: 500 });
  }
}
