// app/api/transcriptions/route.ts
// List transcriptions from database with filtering

import { NextRequest, NextResponse } from 'next/server';
import { prisma } from '@/lib/db/prisma';
import { verifyToken } from '@/lib/auth/jwt';

export async function GET(request: NextRequest) {
  try {
    // Get token from cookie
    const token = request.cookies.get('token')?.value;

    if (!token) {
      return NextResponse.json(
        { error: 'Authentication required' },
        { status: 401 }
      );
    }

    // Verify token
    const decoded = verifyToken(token);
    if (!decoded) {
      return NextResponse.json(
        { error: 'Invalid or expired token' },
        { status: 401 }
      );
    }

    // Get query parameters
    const { searchParams } = new URL(request.url);
    const startDate = searchParams.get('startDate');
    const endDate = searchParams.get('endDate');
    const searchText = searchParams.get('search');
    const storeId = searchParams.get('storeId');

    // Build filters
    let dateFilter = '';
    let roleFilter = '';
    let storeFilter = '';
    let searchFilter = '';
    const params: any[] = [];

    // Date filter
    if (startDate && endDate) {
      dateFilter = 'AND t.created_at BETWEEN $1::timestamp AND $2::timestamp';
      params.push(startDate, endDate);
    }

    // Role-based filter
    if (decoded.role !== 'super_admin') {
      // Admin sees only their stores
      if (params.length > 0) {
        roleFilter = 'AND r.admin_id = $' + (params.length + 1);
        params.push(decoded.adminId);
      } else {
        roleFilter = 'AND r.admin_id = $1';
        params.push(decoded.adminId);
      }
    }

    // Store filter (optional - for filtering by specific store)
    if (storeId) {
      const storeParam = params.length + 1;
      storeFilter = `AND t.store_id = $${storeParam}`;
      params.push(parseInt(storeId));
    }

    // Text search filter
    if (searchText) {
      const searchParam = params.length + 1;
      searchFilter = `AND t.transcript_text ILIKE $${searchParam}`;
      params.push(`%${searchText}%`);
    }

    // Query transcriptions
    const result = await prisma.$queryRawUnsafe<any[]>(`
      SELECT 
        t.transcription_id,
        t.store_id,
        t.conversation_id,
        t.session_id,
        t.transcript_text,
        t.duration_seconds,
        t.word_count,
        t.created_at,
        t.fetched_at,
        s.name as store_name,
        loc.name as location_name
      FROM transcriptions t
      JOIN store s ON t.store_id = s.store_id
      JOIN restaurant r ON s.restaurant_id = r.restaurant_id
      LEFT JOIN location loc ON s.location_id = loc.location_id
      WHERE 1=1
      ${dateFilter}
      ${roleFilter}
      ${storeFilter}
      ${searchFilter}
      ORDER BY t.created_at DESC
      LIMIT 100
    `, ...params);

    // Format transcriptions
    const transcriptions = result.map((row) => ({
      transcriptionId: Number(row.transcription_id),
      storeId: Number(row.store_id),
      storeName: row.store_name,
      locationName: row.location_name,
      conversationId: row.conversation_id,
      sessionId: row.session_id,
      transcriptText: row.transcript_text,
      preview: row.transcript_text.substring(0, 150) + '...', // Preview for UI
      durationSeconds: row.duration_seconds ? Number(row.duration_seconds) : null,
      wordCount: row.word_count ? Number(row.word_count) : null,
      createdAt: row.created_at.toISOString(),
      fetchedAt: row.fetched_at.toISOString(),
    }));

    return NextResponse.json({
      success: true,
      transcriptions,
      total: transcriptions.length,
    });

  } catch (error) {
    console.error('Get transcriptions error:', error);
    return NextResponse.json(
      { error: 'Failed to fetch transcriptions' },
      { status: 500 }
    );
  }
}
