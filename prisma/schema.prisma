generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  adminId          Int                @id @default(autoincrement()) @map("admin_id")
  email            String             @unique @db.VarChar(255)
  passwordHash     String             @map("password_hash") @db.VarChar(255)
  role             String             @db.VarChar(20)
  isActive         Boolean?           @default(true) @map("is_active")
  createdAt        DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  stripeCustomerId String?            @unique @map("stripe_customer_id") @db.VarChar(255)
  companyName      String?            @map("company_name") @db.VarChar(255)
  companyAddress   String?            @map("company_address")
  companyPhone     String?            @map("company_phone") @db.VarChar(50)
  companyFax       String?            @map("company_fax") @db.VarChar(50)
  companyUrl       String?            @map("company_url") @db.VarChar(255)
  subscription     AdminSubscription?
  restaurants      Restaurant[]

  @@index([stripeCustomerId], map: "idx_admin_stripe_customer")
  @@map("admin")
}

model AdminSubscription {
  subscriptionId               Int              @id @default(autoincrement()) @map("subscription_id")
  adminId                      Int              @unique @map("admin_id")
  stripeSubscriptionId         String?          @unique @map("stripe_subscription_id") @db.VarChar(255)
  stripeCustomerId             String?          @map("stripe_customer_id") @db.VarChar(255)
  stripePriceId                String?          @map("stripe_price_id") @db.VarChar(255)
  monthlyCost                  Decimal          @map("monthly_cost") @db.Decimal(10, 2)
  creditsLimit                 Int              @default(1000) @map("credits_limit")
  overageCostPer100            Decimal          @default(5.00) @map("overage_cost_per_100") @db.Decimal(10, 2)
  creditsUsed                  Int              @default(0) @map("credits_used")
  creditsResetDate             DateTime?        @map("credits_reset_date") @db.Timestamp(6)
  lastOverageCheck             DateTime?        @map("last_overage_check") @db.Timestamp(6)
  billingCycleDay              Int              @map("billing_cycle_day")
  currentPeriodStart           DateTime?        @map("current_period_start") @db.Timestamp(6)
  currentPeriodEnd             DateTime?        @map("current_period_end") @db.Timestamp(6)
  nextBillingDate              DateTime?        @map("next_billing_date") @db.Timestamp(6)
  status                       String           @default("active") @db.VarChar(50)
  featureRestaurant            Boolean          @default(false) @map("feature_restaurant")
  featureReports               Boolean          @default(false) @map("feature_reports")
  featureDownloadAudio         Boolean          @default(false) @map("feature_download_audio")
  featureDownloadTranscription Boolean          @default(false) @map("feature_download_transcription")
  featureBulkSms               Boolean          @default(false) @map("feature_bulk_sms")
  featureSmsConfirmation       Boolean          @default(false) @map("feature_sms_confirmation")
  createdAt                    DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                    DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  canceledAt                   DateTime?        @map("canceled_at") @db.Timestamp(6)
  admin                        Admin            @relation(fields: [adminId], references: [adminId], onDelete: Cascade, onUpdate: NoAction)
  creditUsageLogs              CreditUsageLog[]
  overageCharges               OverageCharge[]

  @@index([adminId], map: "idx_admin_subscriptions_admin_id")
  @@index([nextBillingDate], map: "idx_admin_subscriptions_billing_date")
  @@index([status], map: "idx_admin_subscriptions_status")
  @@index([stripeSubscriptionId], map: "idx_admin_subscriptions_stripe_subscription")
  @@map("admin_subscriptions")
}

model OverageCharge {
  chargeId            Int               @id @default(autoincrement()) @map("charge_id")
  subscriptionId      Int               @map("subscription_id")
  creditsOverLimit    Int               @map("credits_over_limit")
  amountCharged       Decimal           @map("amount_charged") @db.Decimal(10, 2)
  billingPeriodStart  DateTime          @map("billing_period_start") @db.Timestamp(6)
  billingPeriodEnd    DateTime          @map("billing_period_end") @db.Timestamp(6)
  stripeInvoiceItemId String?           @map("stripe_invoice_item_id") @db.VarChar(255)
  stripeInvoiceId     String?           @map("stripe_invoice_id") @db.VarChar(255)
  status              String            @default("pending") @map("status") @db.VarChar(50)
  chargedAt           DateTime          @default(now()) @map("charged_at") @db.Timestamp(6)
  adminSubscription   AdminSubscription @relation(fields: [subscriptionId], references: [subscriptionId], onDelete: Cascade, onUpdate: NoAction)

  @@index([chargedAt(sort: Desc)], map: "idx_overage_charges_charged_at")
  @@index([status], map: "idx_overage_charges_status")
  @@index([subscriptionId], map: "idx_overage_charges_subscription")
  @@map("overage_charges")
}

model CreditUsageLog {
  logId               BigInt            @id @default(autoincrement()) @map("log_id")
  subscriptionId      Int               @map("subscription_id")
  creditsDelta        Int               @map("credits_delta")
  creditsBalanceAfter Int               @map("credits_balance_after")
  source              String            @map("source") @db.VarChar(100)
  sourceId            String?           @map("source_id") @db.VarChar(255)
  sourceMetadata      Json?             @map("source_metadata")
  loggedAt            DateTime          @default(now()) @map("logged_at") @db.Timestamp(6)
  loggedBy            String?           @map("logged_by") @db.VarChar(100)
  adminSubscription   AdminSubscription @relation(fields: [subscriptionId], references: [subscriptionId], onDelete: Cascade, onUpdate: NoAction)

  @@index([loggedAt(sort: Desc)], map: "idx_credit_usage_log_logged_at")
  @@index([source], map: "idx_credit_usage_log_source")
  @@index([subscriptionId], map: "idx_credit_usage_log_subscription")
  @@map("credit_usage_log")
}

model Restaurant {
  restaurantId  Int            @id @default(autoincrement()) @map("restaurant_id")
  adminId       Int            @map("admin_id")
  name          String         @db.VarChar(100)
  isActive      Boolean?       @default(true) @map("is_active")
  createdAt     DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  menuTemplates MenuTemplate[]
  admin         Admin          @relation(fields: [adminId], references: [adminId], onDelete: Cascade, onUpdate: NoAction)
  stores        Store[]

  @@map("restaurant")
}

model Location {
  locationId Int       @id @default(autoincrement()) @map("location_id")
  name       String    @unique @db.VarChar(100)
  isActive   Boolean?  @default(true) @map("is_active")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  stores     Store[]

  @@map("location")
}

/// This model contains an index with non-default null sort order and requires additional setup for migrations. Visit https://pris.ly/d/default-index-null-ordering for more info.
model Store {
  storeId             Int                  @id @default(autoincrement()) @map("store_id")
  restaurantId        Int                  @map("restaurant_id")
  locationId          Int                  @map("location_id")
  address             String
  phonePrimary        String?              @map("phone_primary") @db.VarChar(20)
  phoneSecondary      String?              @map("phone_secondary") @db.VarChar(20)
  aiAgentId           String?              @map("ai_agent_id") @db.VarChar(100)
  aiPlatformName      String?              @map("ai_platform_name") @db.VarChar(50)
  isAiAgentEnabled    Boolean?             @default(true) @map("is_ai_agent_enabled")
  timeZone            String?              @default("America/Toronto") @map("time_zone") @db.VarChar(63)
  isActive            Boolean?             @default(true) @map("is_active")
  lastPing            DateTime?            @map("last_ping") @db.Timestamp(6)
  createdAt           DateTime?            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime?            @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  lastSyncAt          DateTime?            @map("last_sync_at") @db.Timestamp(6)
  lastSyncId          String?              @map("last_sync_id") @db.VarChar(255)
  syncStatus          String?              @default("idle") @map("sync_status") @db.VarChar(20)
  syncError           String?              @map("sync_error")
  syncedConversations Int?                 @default(0) @map("synced_conversations")
  menuItemAssignments MenuItemAssignment[]
  orders              Order[]
  prompt              Prompt?
  location            Location             @relation(fields: [locationId], references: [locationId], onDelete: NoAction, onUpdate: NoAction)
  restaurant          Restaurant           @relation(fields: [restaurantId], references: [restaurantId], onDelete: Cascade, onUpdate: NoAction)
  storeHours          StoreHours[]
  subscription        Subscription?
  transcriptions      Transcription[]

  @@index([isAiAgentEnabled], map: "idx_store_enabled")
  @@index([lastSyncAt(sort: Desc)], map: "idx_store_last_sync_at")
  @@index([locationId], map: "idx_store_location")
  @@index([restaurantId], map: "idx_store_restaurant")
  @@index([syncStatus], map: "idx_store_sync_status")
  @@index([timeZone], map: "idx_store_time_zone")
  @@map("store")
}

model StoreHours {
  storeHourId Int       @id @default(autoincrement()) @map("store_hour_id")
  storeId     Int       @map("store_id")
  dayOfWeek   Int       @map("day_of_week") @db.SmallInt
  openTime    DateTime  @map("open_time") @db.Time(6)
  closeTime   DateTime  @map("close_time") @db.Time(6)
  isClosed    Boolean?  @default(false) @map("is_closed")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  store       Store     @relation(fields: [storeId], references: [storeId], onDelete: Cascade, onUpdate: NoAction)

  @@unique([storeId, dayOfWeek], map: "idx_store_day_unique")
  @@index([openTime, closeTime], map: "idx_store_hours_open")
  @@map("store_hours")
}

model Customer {
  customerId             Int       @id @default(autoincrement()) @map("customer_id")
  phoneNumberId          String?   @map("phone_number_id") @db.VarChar(20)
  phoneNumberProvided    String?   @map("phone_number_provided") @db.VarChar(20)
  name                   String?   @db.VarChar(100)
  sessionToken           String?   @default(dbgenerated("gen_random_uuid()")) @map("session_token") @db.Uuid
  email                  String?   @db.VarChar(255)
  preferredContactMethod String?   @default("call") @map("preferred_contact_method") @db.VarChar(10)
  isActive               Boolean?  @default(true) @map("is_active")
  createdAt              DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([phoneNumberId], map: "idx_customer_phone_id")
  @@index([phoneNumberProvided], map: "idx_customer_phone_provided")
  @@index([sessionToken], map: "idx_customer_session_token")
  @@map("customer")
}

model Plans {
  planId          Int            @id @default(autoincrement()) @map("plan_id")
  name            String         @db.VarChar(50)
  stripe_price_id String         @db.VarChar(100)
  price           Decimal        @db.Decimal(10, 2)
  features        Json?
  isActive        Boolean?       @default(true) @map("is_active")
  createdAt       DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  subscriptions   Subscription[]

  @@map("plans")
}

model Subscription {
  subscriptionId       Int       @id @default(autoincrement()) @map("subscription_id")
  store_id             Int       @unique
  stripeSubscriptionId String    @map("stripe_subscription_id") @db.VarChar(100)
  planId               Int       @map("plan_id")
  status               String    @db.VarChar(20)
  start_date           DateTime  @db.Timestamp(6)
  end_date             DateTime? @db.Timestamp(6)
  credit_amount        Decimal?  @default(0.0) @db.Decimal(10, 2)
  updatedAt            DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  plan                 Plans     @relation(fields: [planId], references: [planId], onUpdate: NoAction)
  store                Store     @relation(fields: [store_id], references: [storeId], onDelete: Cascade, onUpdate: NoAction)

  @@map("subscription")
}

model Prompt {
  promptId  Int       @id @default(autoincrement()) @map("prompt_id")
  storeId   Int       @unique @map("store_id")
  content   String
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  store     Store     @relation(fields: [storeId], references: [storeId], onDelete: Cascade, onUpdate: NoAction)

  @@map("prompt")
}

model MenuTemplate {
  templateId          Int                  @id @default(autoincrement()) @map("template_id")
  restaurantId        Int                  @map("restaurant_id")
  name                String               @db.VarChar(100)
  description         String?
  basePrice           Decimal              @map("base_price") @db.Decimal(10, 2)
  categoryId          Int?                 @map("category_id")
  imageUrl            String?              @map("image_url") @db.VarChar(500)
  calories            Int?
  isActive            Boolean?             @default(true) @map("is_active")
  createdAt           DateTime?            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime?            @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  menuItemAssignments MenuItemAssignment[]
  subItems            MenuSubItem[]
  menuCategory        MenuCategory?        @relation(fields: [categoryId], references: [categoryId], onDelete: NoAction, onUpdate: NoAction)
  restaurant          Restaurant           @relation(fields: [restaurantId], references: [restaurantId], onDelete: Cascade, onUpdate: NoAction)
  orderItems          OrderItem[]

  @@index([isActive], map: "idx_menu_template_active")
  @@index([categoryId], map: "idx_menu_template_category")
  @@index([restaurantId], map: "idx_menu_template_restaurant")
  @@map("menu_template")
}

model MenuSubItem {
  subItemId   Int          @id @default(autoincrement()) @map("sub_item_id")
  templateId  Int          @map("template_id")
  quantity    Int?         @default(1)
  name        String       @db.VarChar(100)
  description String?
  is_active   Boolean?     @default(true)
  createdAt   DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at  DateTime?    @default(now()) @db.Timestamp(6)
  template    MenuTemplate @relation(fields: [templateId], references: [templateId], onDelete: Cascade, onUpdate: NoAction)

  @@index([templateId], map: "idx_menu_sub_item_template_id")
  @@map("menu_sub_item")
}

model MenuItemAssignment {
  assignmentId   Int                 @id @default(autoincrement()) @map("assignment_id")
  storeId        Int                 @map("store_id")
  templateId     Int                 @map("template_id")
  isAvailable    Boolean?            @default(true) @map("is_available")
  display_order  Int?                @default(99) @db.SmallInt
  createdAt      DateTime?           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime?           @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  store          Store               @relation(fields: [storeId], references: [storeId], onDelete: Cascade, onUpdate: NoAction)
  template       MenuTemplate        @relation(fields: [templateId], references: [templateId], onDelete: Cascade, onUpdate: NoAction)
  priceOverrides MenuPriceOverride[]

  @@unique([storeId, templateId])
  @@index([isAvailable], map: "idx_menu_assignment_available")
  @@index([storeId], map: "idx_menu_assignment_store")
  @@index([templateId], map: "idx_menu_assignment_template")
  @@map("menu_item_assignment")
}

model MenuPriceOverride {
  overrideId      Int                @id @default(autoincrement()) @map("override_id")
  assignmentId    Int                @map("assignment_id")
  overriddenPrice Decimal            @map("overridden_price") @db.Decimal(10, 2)
  reason          String?            @map("reason") @db.VarChar(100)
  effectiveFrom   DateTime?          @default(now()) @map("effective_from") @db.Timestamp(6)
  expiresAt       DateTime?          @map("expires_at") @db.Timestamp(6)
  createdAt       DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  assignment      MenuItemAssignment @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade, onUpdate: NoAction)

  @@index([assignmentId], map: "idx_menu_override_assignment")
  @@index([expiresAt], map: "idx_menu_override_expires")
  @@map("menu_price_override")
}

model OrderType {
  orderTypeId Int       @id @default(autoincrement()) @map("order_type_id")
  name        String    @db.VarChar(50)
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  orders      Order[]

  @@map("order_types")
}

model Order {
  orderId            Int         @id @default(autoincrement()) @map("order_id")
  storeId            Int         @map("store_id")
  customerId         String      @map("customer_id") @db.VarChar(20)
  sessionId          String      @map("session_id") @db.VarChar(36)
  system_caller_id   String?     @db.VarChar(36)
  printerStatus      String      @default("pending") @map("printer_status") @db.VarChar(10)
  totalPrice         Decimal     @map("total_price") @db.Decimal(10, 2)
  order_type         Int
  notes              String?
  pickup_time        DateTime?   @db.Timestamptz(6)
  transcript_summary String?
  is_cancel          Boolean?    @default(false)
  createdAt          DateTime?   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  orderItems         OrderItem[]
  order_types        OrderType   @relation(fields: [order_type], references: [orderTypeId], onDelete: NoAction, onUpdate: NoAction)
  store              Store       @relation(fields: [storeId], references: [storeId], onDelete: NoAction, onUpdate: NoAction)

  @@index([customerId], map: "idx_order_customer_id")
  @@index([printerStatus], map: "idx_order_printer_status")
  @@index([sessionId], map: "idx_order_session")
  @@index([storeId, createdAt], map: "idx_order_store_created")
  @@map("orders")
}

model OrderItem {
  orderItemId      Int          @id @default(autoincrement()) @map("order_item_id")
  orderId          Int          @map("order_id")
  templateId       Int          @map("template_id")
  quantity         Int          @default(1)
  priceAtTime      Decimal      @map("price_at_time") @db.Decimal(10, 2)
  customerRequests String?      @map("customer_requests") @db.VarChar(120)
  isCancel         Boolean?     @default(false) @map("is_cancel")
  createdAt        DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  order            Order        @relation(fields: [orderId], references: [orderId], onDelete: Cascade, onUpdate: NoAction)
  template         MenuTemplate @relation(fields: [templateId], references: [templateId], onDelete: NoAction, onUpdate: NoAction)

  @@index([orderId], map: "idx_order_item_order")
  @@index([templateId], map: "idx_order_item_template")
  @@map("order_item")
}

model OrderCaptureLog {
  id             Int       @id @default(autoincrement())
  conversationId String    @map("conversation_id") @db.VarChar(100)
  eventType      String?   @map("event_type") @db.VarChar(150)
  status         String    @map("status") @db.VarChar(50)
  requestHeaders Json?     @map("request_headers")
  requestBody    Json?     @map("request_body")
  errorMessage   String?   @map("error_message")
  receivedAt     DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt    DateTime? @map("processed_at") @db.Timestamptz(6)
  requestId      String?   @default(dbgenerated("gen_random_uuid()")) @map("request_id") @db.Uuid
  durationMs     Int?      @map("duration_ms")

  @@index([conversationId], map: "idx_order_capture_logs_conversation_id")
  @@index([receivedAt(sort: Desc)], map: "idx_order_capture_logs_received_at")
  @@index([status], map: "idx_order_capture_logs_status")
  @@map("order_capture_logs")
}

model PrintLog {
  logId        Int      @id @default(autoincrement()) @map("log_id")
  orderId      Int      @map("order_id")
  printerName  String?  @map("printer_name") @db.VarChar(150)
  status       String   @map("status") @db.VarChar(50)
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "idx_print_logs_created_at")
  @@index([orderId], map: "idx_print_logs_order_id")
  @@index([status], map: "idx_print_logs_status")
  @@map("print_logs")
}

model MenuCategory {
  categoryId    Int            @id @default(autoincrement()) @map("category_id")
  name          String         @unique @db.VarChar(50)
  description   String?
  displayOrder  Int?           @default(99) @map("display_order") @db.SmallInt
  isActive      Boolean?       @default(true) @map("is_active")
  createdAt     DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  menuTemplates MenuTemplate[]

  @@map("menu_category")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Transcription {
  transcriptionId Int       @id @default(autoincrement()) @map("transcription_id")
  storeId         Int       @map("store_id")
  conversationId  String    @map("conversation_id") @db.VarChar(255)
  sessionId       String?   @map("session_id") @db.VarChar(255)
  transcriptText  String    @map("transcript_text")
  durationSeconds Int?      @map("duration_seconds")
  wordCount       Int?      @map("word_count")
  createdAt       DateTime  @map("created_at") @db.Timestamp(6)
  fetchedAt       DateTime? @default(now()) @map("fetched_at") @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)
  metadata        Json?
  customerName    String?   @map("customer_name") @db.VarChar(255)
  phoneNumberId   String?   @map("phone_number_id") @db.VarChar(50)
  phoneNumber     String?   @map("phone_number") @db.VarChar(50)
  store           Store     @relation(fields: [storeId], references: [storeId], onDelete: Cascade, onUpdate: NoAction)

  @@unique([storeId, conversationId], map: "unique_conversation_per_store")
  @@index([conversationId], map: "idx_transcriptions_conversation")
  @@index([storeId, createdAt(sort: Desc)], map: "idx_transcriptions_store_created")
  @@index([customerName], map: "idx_transcriptions_customer_name")
  @@index([phoneNumber], map: "idx_transcriptions_phone_number")
  @@map("transcriptions")
}
